---
interface Props {
  href: string;
  title: string;
  aliases?: string[];
  summary?: string;
  portrait?: string;
}
const { href, title, aliases, summary, portrait } = Astro.props;
---
<li class="entity-card">
  <a href={href}>
    {portrait
      ? <img src={`/_assets/${portrait}`} alt="" class="portrait-thumb" />
      : <span class="portrait-placeholder" aria-hidden="true"></span>
    }
    <div class="text">
      <h3>{title}</h3>
      {aliases && aliases.length > 0 && (
        <p class="aliases"><em>also: {aliases.join(', ')}</em></p>
      )}
      {summary && <p class="summary">{summary}</p>}
    </div>
  </a>
</li>

<style>
  .entity-card {
    margin: 0;
    list-style: none;
  }
  .entity-card a {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-3);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--fg);
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }
  .entity-card a:hover,
  .entity-card a:focus-visible {
    background: var(--surface);
    border-color: var(--border);
  }
  .portrait-thumb,
  .portrait-placeholder {
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    object-fit: cover;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .portrait-placeholder {
    background: var(--tint-blue);
    border-color: var(--border);
  }
  .text { flex: 1 1 auto; min-width: 0; }
  .entity-card h3 {
    margin: 0 0 var(--space-1);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--fg);
  }
  .entity-card a:hover h3 { color: var(--link); }
  .aliases {
    margin: 0 0 var(--space-1);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .summary {
    margin: 0;
    font-size: var(--fs-sm);
    color: var(--muted);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-clamp: 2;
  }
</style>
