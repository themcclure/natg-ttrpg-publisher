---
import '../styles/theme.css';
import '../styles/base.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const siteTitle = 'NATG Encyclopedia';
const pageTitle = title === siteTitle ? siteTitle : `${title} — ${siteTitle}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <link rel="preload" href="/fonts/InterVariable-latin.woff2" as="font" type="font/woff2" crossorigin />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-title">{siteTitle}</a>
        <nav aria-label="Primary" class="site-nav">
          <ul>
            <li><a href="/characters/">Characters</a></li>
            <li><a href="/encyclopedia/">Encyclopedia</a></li>
            <li><a href="/episodes/">Episode Log</a></li>
            <li><a href="/about/">About</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="disclaimer">
          Unofficial fan project. Star Trek and related marks are trademarks of
          Paramount/CBS. Not affiliated with or endorsed by the rights holders.
          <a href="/about/">About this site</a>.
        </p>
        <p class="copyright">
          Campaign content &copy; Mike McClure. Publisher code under MIT.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .site-header__inner {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-4) var(--space-6);
  }
  .site-title {
    font-size: var(--fs-md);
    font-weight: 700;
    text-decoration: none;
    color: var(--fg);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    flex: 0 0 auto;
  }
  .site-title::before {
    content: '';
    display: inline-block;
    width: var(--space-3);
    height: var(--space-3);
    background: var(--accent);
    border-radius: var(--radius-pill);
    margin-right: var(--space-3);
    transform: translateY(-1px);
  }
  .site-title:hover { color: var(--accent); }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: var(--space-5);
  }
  .site-nav li { margin: 0; }
  .site-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: var(--space-2) 0;
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--fg);
    border-bottom-color: var(--accent);
  }

  .site-footer {
    margin-top: var(--space-8);
    border-top: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .site-footer__inner {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: var(--space-5);
  }
  .site-footer p { margin: 0 0 var(--space-2); }
  .site-footer .disclaimer,
  .site-footer .copyright { color: var(--muted); }
  .site-footer a { color: var(--link); }

  @media (max-width: 480px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .site-nav ul { gap: var(--space-4); }
  }
</style>
