---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import EntityMeta from '../../../components/EntityMeta.astro';
import Backlinks from '../../../components/Backlinks.astro';
import { entityUrl } from '../../../lib/urls.ts';
import { getLocationNode } from '../../../lib/locations.ts';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('locations');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'locations'> };
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const d = entry.data;
const node = await getLocationNode(entry.id);
const url = entityUrl('locations', entry.id);

// Container breadcrumb chain — root → parent (excluding self).
const ancestors = node?.ancestors ?? [];
const children = node?.children ?? [];
---
<Layout title={d.title} description={d.summary}>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Encyclopedia', href: '/encyclopedia/' },
    { label: 'Locations', href: '/encyclopedia/locations/' },
    { label: d.title },
  ]} />
  <article>
    <h1>{d.title}</h1>
    {d.aliases && d.aliases.length > 0 && (
      <p class="aliases"><em>also: {d.aliases.join(', ')}</em></p>
    )}
    {d.portrait && <img src={`/_assets/${d.portrait}`} alt={d.title} class="portrait" />}
    <EntityMeta fields={[
      { label: 'Kind', value: d.kind },
      { label: 'Sovereignty', value: d.sovereignty },
    ]} />

    {ancestors.length > 0 ? (
      <nav class="hierarchy" aria-label="Location hierarchy">
        <span class="hierarchy-label">Within: </span>
        <ol class="hierarchy-chain">
          {ancestors.map((a) => (
            <li><a href={a.url}>{a.title}</a></li>
          ))}
        </ol>
      </nav>
    ) : node?.containerUnresolved ? (
      <p class="hierarchy hierarchy-unresolved">
        Within: <em>{node.containerRaw}</em> <small>(container reference unresolved)</small>
      </p>
    ) : (
      <p class="hierarchy hierarchy-root"><em>Top-level location.</em></p>
    )}

    <div class="body"><Content /></div>

    {children.length > 0 && (
      <section class="contains" aria-labelledby="contains-heading">
        <h2 id="contains-heading">Contains</h2>
        <ul>
          {children.map((c) => (
            <li><a href={c.url}>{c.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <Backlinks url={url} />
  </article>
</Layout>

<style>
  .hierarchy {
    margin: 0 0 var(--space-5);
    padding: var(--space-3) var(--space-4);
    background: var(--tint-orange);
    border-left: 4px solid var(--accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--fs-sm);
  }
  .hierarchy-label {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    font-size: 0.85em;
    margin-right: var(--space-2);
  }
  .hierarchy-chain {
    display: inline-flex;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: var(--space-2);
    align-items: center;
  }
  .hierarchy-chain li {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .hierarchy-chain li:not(:last-child)::after {
    content: '›';
    color: var(--border);
  }
  .hierarchy-chain a {
    color: var(--accent);
    text-decoration: none;
  }
  .hierarchy-chain a:hover { text-decoration: underline; }
  .hierarchy-root,
  .hierarchy-unresolved {
    color: var(--muted);
    font-style: normal;
  }
  .hierarchy-unresolved small {
    margin-left: var(--space-2);
    color: var(--broken);
  }

  .contains {
    margin: var(--space-6) 0 0;
    padding: var(--space-4) var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .contains h2 {
    margin: 0 0 var(--space-3);
    font-size: var(--fs-lg);
  }
  .contains ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }
  .contains li { margin: 0; }
  .contains a {
    color: var(--link);
    text-decoration: none;
  }
  .contains a:hover { text-decoration: underline; }
</style>
