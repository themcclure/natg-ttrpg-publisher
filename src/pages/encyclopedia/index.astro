---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const [npcs, factions, locations, starships, timelines] = await Promise.all([
  getCollection('npcs'),
  getCollection('factions'),
  getCollection('locations'),
  getCollection('starships'),
  getCollection('timelines'),
]);

const sections = [
  { href: '/encyclopedia/npcs/', title: 'NPCs', count: npcs.length },
  { href: '/encyclopedia/factions/', title: 'Factions', count: factions.length },
  { href: '/encyclopedia/locations/', title: 'Locations', count: locations.length },
  { href: '/encyclopedia/starships/', title: 'Starships', count: starships.length },
  { href: '/encyclopedia/timelines/', title: 'Timelines', count: timelines.length },
];
---
<Layout title="Encyclopedia">
  <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Encyclopedia' }]} />
  <h1>Encyclopedia</h1>
  <p>World reference: people, places, ships, and events the crew has encountered.</p>
  <ul class="encyclopedia-tiles">
    {sections.map((s) => (
      <li>
        <a href={s.href}>
          <h2>{s.title}</h2>
          <p>{s.count} {s.count === 1 ? 'entry' : 'entries'}</p>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .encyclopedia-tiles {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  .encyclopedia-tiles li { margin: 0; }
  .encyclopedia-tiles a {
    display: block;
    padding: var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--link);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    text-decoration: none;
    color: var(--fg);
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }
  .encyclopedia-tiles a:hover,
  .encyclopedia-tiles a:focus-visible {
    background: var(--tint-blue);
    border-left-color: var(--accent);
  }
  .encyclopedia-tiles h2 {
    margin: 0 0 var(--space-1);
    font-size: var(--fs-lg);
    color: var(--fg);
  }
  .encyclopedia-tiles a:hover h2 { color: var(--link); }
  .encyclopedia-tiles p {
    margin: 0;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  @media (min-width: 600px) {
    .encyclopedia-tiles { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .encyclopedia-tiles { grid-template-columns: repeat(3, 1fr); }
  }
</style>
