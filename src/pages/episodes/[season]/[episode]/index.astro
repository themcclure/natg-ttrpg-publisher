---
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { seasonOf } from '../../../../lib/episodes.ts';
import { loadSeason, listPdfHandouts, episodeFromHandoutId } from '../../../../lib/content.ts';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes.map((entry) => ({
    params: { season: seasonOf(entry.data.episode), episode: entry.data.episode },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'episodes'> };
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const d = entry.data;
const season = seasonOf(d.episode);
const seasonMeta = await loadSeason(season);

const mdHandouts = (await getCollection('handouts'))
  .filter((h) => episodeFromHandoutId(h.id) === d.episode)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const pdfHandouts = await listPdfHandouts(d.episode);

function formatBytes(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / 1024 / 1024).toFixed(2)} MB`;
}

function handoutSlug(id: string): string {
  // id shape: "S00E01/captains-log" → slug "captains-log"
  const parts = id.split('/');
  return parts.slice(1).join('-');
}
---
<Layout title={`${d.episode} — ${d.title}`} description={d.teaser}>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Episode Log', href: '/episodes/' },
    { label: seasonMeta.displayName, href: `/episodes/${season}/` },
    { label: `${d.episode} ${d.title}` },
  ]} />
  <article>
    <h1>{d.episode} — {d.title}</h1>
    <p class="air-date"><time datetime={d.airDate}>First played: {d.airDate}</time></p>
    {d.aliases && d.aliases.length > 0 && (
      <p class="aliases"><em>also: {d.aliases.join(', ')}</em></p>
    )}
    {d.portrait && <img src={`/_assets/${d.portrait}`} alt={`${d.episode} key art`} class="portrait" />}
    <div class="body"><Content /></div>

    {(mdHandouts.length > 0 || pdfHandouts.length > 0) && (
      <section class="handouts" aria-labelledby="handouts-heading">
        <h2 id="handouts-heading">Handouts</h2>
        <ul>
          {mdHandouts.map((h) => (
            <li>
              <a href={`/episodes/${season}/${d.episode}/handouts/${handoutSlug(h.id)}/`}>
                {h.data.title}
              </a>
              {h.data.kind && <span class="kind">{h.data.kind}</span>}
            </li>
          ))}
          {pdfHandouts.map((p) => (
            <li>
              <a href={`/_assets/${p.filename}`} download>
                {p.filename}
              </a>
              <span class="kind">PDF</span>
              <span class="size">{formatBytes(p.size)}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Layout>

<style>
  article > h1 {
    margin-bottom: var(--space-2);
  }
  article > .air-date {
    margin: 0 0 var(--space-2);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .handouts {
    margin: var(--space-7) 0 0;
    padding: var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--link);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  }
  .handouts h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--fs-lg);
  }
  .handouts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .handouts li {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .handouts a {
    color: var(--link);
    text-decoration: none;
    font-weight: 500;
  }
  .handouts a:hover { text-decoration: underline; }
  .handouts .kind {
    font-size: var(--fs-sm);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius-pill);
    padding: 1px var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .handouts .size {
    font-size: var(--fs-sm);
    color: var(--muted);
    font-family: var(--font-mono);
  }
</style>
