---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EntityCard from '../../components/EntityCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('characters')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---
<Layout title="Characters">
  <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Characters' }]} />
  <h1>Characters</h1>
  <p>The party.</p>
  <ul class="entity-list">
    {entries.map((e) => (
      <EntityCard
        href={`/characters/${e.id}/`}
        title={e.data.title}
        aliases={e.data.aliases}
        summary={e.data.summary}
        portrait={e.data.portrait}
      />
    ))}
  </ul>
</Layout>
