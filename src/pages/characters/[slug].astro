---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EntityMeta from '../../components/EntityMeta.astro';
import Backlinks from '../../components/Backlinks.astro';
import { entityUrl } from '../../lib/urls.ts';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('characters');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'characters'> };
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const d = entry.data;
---
<Layout title={d.title} description={d.summary}>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Characters', href: '/characters/' },
    { label: d.title },
  ]} />
  <article>
    <h1>{d.title}</h1>
    {d.aliases && d.aliases.length > 0 && (
      <p class="aliases"><em>also: {d.aliases.join(', ')}</em></p>
    )}
    {d.portrait && <img src={`/_assets/${d.portrait}`} alt={`Portrait of ${d.title}`} class="portrait" />}
    <EntityMeta fields={[
      { label: 'Species', value: d.species },
      { label: 'Affiliation', value: d.affiliation },
      { label: 'Role', value: d.role },
      { label: 'Played by', value: d.player },
    ]} />
    <div class="body"><Content /></div>
    <Backlinks url={entityUrl('characters', entry.id)} />
  </article>
</Layout>
