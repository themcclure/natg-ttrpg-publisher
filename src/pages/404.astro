---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Not found">
  <div class="not-found">
    <p class="code">Error 404</p>
    <h1>That page doesn't exist in this universe.</h1>
    <p class="signal">No signal returned from this sector.</p>
    <p><a href="/">Return to the main viewscreen.</a></p>
  </div>
</Layout>

<style>
  .not-found {
    max-width: var(--max-content);
    margin: var(--space-7) auto;
    text-align: center;
  }
  .not-found .code {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .not-found h1 {
    margin: 0 0 var(--space-3);
    font-size: var(--fs-xl);
  }
  .not-found .signal {
    color: var(--muted);
    margin: 0 0 var(--space-5);
  }
</style>
